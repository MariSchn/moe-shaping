+            full per-expert vector per layer, averaged over micro-batches, then report pooled
+            quantiles over all experts of all MoE layers). For "max"/"min" untouched (dense)
+            layers keep their -/+inf seed and are ignored by the final max()/min(); for "collect"
+            they keep the all-zero seed and are dropped before pooling. Defaults to "sum".
     """
     # Skip aux loss logging if layer_number is None.
     if layer_number is None:
@@ -893,8 +913,26 @@ def save_to_aux_losses_tracker(
