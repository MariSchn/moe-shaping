+    else:
+        # "sum": additive losses; "collect": accumulate the per-expert vector across
+        # micro-batches (averaged by loss_scale in track_moe_metrics).
+        tracker[name]["values"][idx] += value
     tracker[name]["reduce_group"] = reduce_group
     tracker[name]["avg_group"] = avg_group
     tracker[name]["reduce_group_has_dp"] = reduce_group_has_dp
@@ -904,7 +942,9 @@ def clear_aux_losses_tracker() -> None:
     """Clear the auxiliary losses."""
     tracker = get_moe_layer_wise_logging_tracker()
     for name in tracker:
-        tracker[name]["values"].zero_()
+        # Reset to the reduction's identity so the next window starts clean
+        # ("sum" -> 0, "max" -> -inf, "min" -> +inf).
+        tracker[name]["values"].fill_(_AUX_LOSS_TRACKER_INIT[tracker[name].get("reduce_op", "sum")])
 
 
