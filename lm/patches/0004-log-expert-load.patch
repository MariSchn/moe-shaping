     return final_probs, final_map
 
 
+# Seed value for a freshly-initialized / cleared tracker slot, per reduction op. It is the
+# identity element of the op so that a layer which never writes does not affect the result
+# ("sum" -> 0, "max" -> -inf, "min" -> +inf, the latter two being ignored by max()/min();
+# "collect" -> 0, dense layers stay all-zero and are dropped before pooling quantiles).
+_AUX_LOSS_TRACKER_INIT = {"sum": 0.0, "max": float("-inf"), "min": float("inf"), "collect": 0.0}
+
+# Quantiles (in [0, 1]) of the per-expert load distribution, pooled over all experts of all MoE
+# layers and logged as "load/p10".."load/p90" alongside "load/min" (the p0 extreme) and
+# "load/max" (p100). Edit this tuple to change which quantiles are reported.
+_LOAD_QUANTILES = (0.10, 0.25, 0.50, 0.75, 0.90)
+
+
