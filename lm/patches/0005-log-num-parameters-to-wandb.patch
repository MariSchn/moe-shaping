# Patch: Log total model parameter count to W&B at startup
#
# Problem:
#   Megatron-LM prints the per-rank parameter count to stdout but never records
#   the model's total parameter count anywhere durable. For an efficiency study
#   that sweeps model/layer/expert configs, it is useful to have the total
#   parameter count attached to each W&B run so it can be checked afterwards.
#
# What this patch does:
#   In get_model() (megatron/training/training.py), right after the existing
#   per-rank "number of parameters" print, it:
#     1. Reduces the local parameter count over the model-parallel group
#        (torch.distributed.all_reduce on mpu.get_model_parallel_group()) so the
#        value is the full TP x PP model size, not just this rank's shard.
#     2. Writes it once to the W&B run config as 'num_parameters'
#        (config.update(..., allow_val_change=True)).
#   The W&B writer only exists on the last rank, which is why this cannot piggy-
#   back on the existing print guard (that fires on dp_rank == 0). The reduction
#   is a no-op for the data-parallel-only configs used here (group size 1) and
#   stays correct under tensor/pipeline parallelism. Expert-parallel sharding
#   (EP > 1) would additionally need a reduction over the expert-model-parallel
#   group; not handled because EP is not used in these runs.
#
# Where in the code:
#   File: megatron/training/training.py
#   Function: get_model()
#   Location: immediately after the `print(' > number of parameters ...')` block.
#
# How to fix if this patch breaks on a future Megatron version:
#   Search for "number of parameters" in training.py / get_model(). Add the
#   all_reduce over mpu.get_model_parallel_group() and the
#   get_wandb_writer().config.update({'num_parameters': ...}) call after the
#   existing num_parameters computation/print.
#
# Applied to: Megatron-LM core_r0.16.0 (applies on top of patches 0001-0004)
#
diff --git a/megatron/training/training.py b/megatron/training/training.py
index 9b64d933f..c0c5e563a 100644
--- a/megatron/training/training.py
+++ b/megatron/training/training.py
@@ -1247,6 +1247,21 @@ def get_model(model_provider_func, model_type=ModelType.encoder_or_decoder, wrap
             flush=True,
         )
 
+    # Log the total number of parameters to W&B once at startup so each run records
+    # its model size. `num_parameters` above is this rank's local shard; reduce over
+    # the model-parallel group to recover the full model size (TP x PP). Correct as-is
+    # for the EP=1 / data-parallel-only configs used here; expert-parallel sharding
+    # would additionally need a reduction over the expert-model-parallel group.
+    total_num_parameters = torch.tensor(
+        [num_parameters], dtype=torch.long, device=torch.cuda.current_device()
+    )
+    torch.distributed.all_reduce(total_num_parameters, group=mpu.get_model_parallel_group())
+    wandb_writer = get_wandb_writer()
+    if wandb_writer:
+        wandb_writer.config.update(
+            {'num_parameters': total_num_parameters.item()}, allow_val_change=True
+        )
+
     # GPU allocation.
     # For FSDP2, we don't allocate GPU memory here. We allocate GPU memory
     # in the fully_shard function of FSDP2 instead.
