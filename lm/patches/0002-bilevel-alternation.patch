+# ---------------------------------------------------------------------------
+# Bilevel / alternating MoE optimization (moe-shaping).
+#
+# Alternates optimizer updates between MoE router params (*.router.*) and MoE
+# expert params (*.experts.*) over a fixed cycle of length
+# (bilevel_router_steps + bilevel_expert_steps). The transformer backbone
+# (attention, embeddings, norms, lm-head) trains every step.
+#
+# The inactive role is "frozen" for the step by masking its optimizer param
+# group(s) learning rate to 0 (Adam's update is lr * m_hat / (sqrt(v_hat)+eps),
+# so lr=0 => no parameter change and, for AdamW, no decoupled weight decay
+# either). Router/expert params were placed in their own param groups, tagged
+# 'bilevel_role', in get_megatron_optimizer_config().
+#
+# Caveats (acceptable for this research use; revisit if exact fidelity needed):
+#   * The inactive group's Adam moments still update from their (real) grads;
+#     a strict two-optimizer scheme would freeze the moments too.
+#   * Global grad-norm clipping sees the inactive group's grads.
+# ---------------------------------------------------------------------------
+_bilevel_step_count = 0
+
+
+def bilevel_enabled(args):
+    """True if router/expert alternation is active."""
+    return bool(getattr(args, 'bilevel_router_steps', 0)) and args.bilevel_router_steps > 0
+
+
+def bilevel_in_router_phase(args):
+    """True if the current optimizer step is a router-only step."""
+    cycle = args.bilevel_router_steps + args.bilevel_expert_steps
+    return (_bilevel_step_count % cycle) < args.bilevel_router_steps
+
+
+def bilevel_apply_lr_mask(optimizer, args):
+    """Zero the lr of the inactive role's param groups before optimizer.step().
+
+    Returns (saved_lrs, phase) where saved_lrs restores the original lrs and
+    phase is 1 for the router phase, 0 for the expert phase.
+    """
+    router_phase = bilevel_in_router_phase(args)
+    inactive_role = 'expert' if router_phase else 'router'
+    saved = []
+    for group in optimizer.param_groups:
+        if group.get('bilevel_role') == inactive_role:
+            saved.append((group, group['lr']))
+            group['lr'] = 0.0
+    return saved, (1 if router_phase else 0)
+
+
+def bilevel_restore_lr(saved):
+    """Restore lrs masked by bilevel_apply_lr_mask()."""
+    for group, lr in saved:
+        group['lr'] = lr
+
+
 def train_step(forward_step_func, data_iterator, model, optimizer, opt_param_scheduler, config, forward_backward_func, iteration=None):
     """Single training step."""
     args = get_args()
@@ -1700,7 +1770,16 @@ def train_step(forward_step_func, data_iterator, model, optimizer, opt_param_sch
     # Update parameters.
 
     timers('optimizer', log_level=1).start(barrier=args.barrier_with_L1_time)
+    # Bilevel alternation: freeze the inactive role's params for this step by
+    # masking their lr to 0, then restore and advance the phase counter.
+    _bilevel_saved = None
+    if bilevel_enabled(args):
+        _bilevel_saved, args.bilevel_phase = bilevel_apply_lr_mask(optimizer, args)
     update_successful, grad_norm, num_zeros_in_grad = optimizer.step()
+    if _bilevel_saved is not None:
+        global _bilevel_step_count
+        bilevel_restore_lr(_bilevel_saved)
+        _bilevel_step_count += 1
 
     # get max attention logit for logging and run clip_qk()
     # Part of MuonClip Optimizer step
@@ -1879,6 +1958,12 @@ def training_log(
     if writer and (iteration % args.tensorboard_log_interval == 0):
         if wandb_writer:
             wandb_writer.log({'samples vs steps': args.consumed_train_samples}, iteration)
+        # Bilevel alternation phase indicator (1 = router-only step, 0 = expert-only step).
+        if bilevel_enabled(args):
+            bilevel_phase = getattr(args, 'bilevel_phase', 0)
+            writer.add_scalar('bilevel/phase', bilevel_phase, iteration)
+            if wandb_writer:
+                wandb_writer.log({'bilevel/phase': bilevel_phase}, iteration)
         if learning_rate is not None:
             writer.add_scalar('learning-rate', learning_rate, iteration)
             writer.add_scalar('learning-rate vs samples', learning_rate, args.consumed_train_samples)
