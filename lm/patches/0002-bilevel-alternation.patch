     # General arguments
     group.add_argument('--num-experts', type=int, default=None,
                        help='Number of Experts in MoE (None means no MoE)')
+    # --- Bilevel / alternating MoE optimization (moe-shaping) ---
+    group.add_argument('--bilevel-router-steps', type=int, default=0,
+                       help='Bilevel alternation: number of consecutive optimizer steps that '
+                            'update ONLY the MoE router params (*.router.*) per cycle. '
+                            '0 disables alternation (joint training).')
+    group.add_argument('--bilevel-expert-steps', type=int, default=1,
+                       help='Bilevel alternation: number of consecutive optimizer steps that '
+                            'update ONLY the MoE expert params (*.experts.*) per cycle.')
+    group.add_argument('--router-lr', type=float, default=None,
+                       help='Per-group learning rate for the MoE router params. '
+                            'Defaults to --lr when unset. Splits the router into its own param group (with or without alternation).')
+    group.add_argument('--expert-lr', type=float, default=None,
+                       help='Per-group learning rate for the MoE expert params. '
+                            'Defaults to --lr when unset. Splits the experts into their own param group (with or without alternation).')
     group.add_argument('--moe-layer-freq', type=moe_freq_type, default=1,
                        help='Frequency between MoE layers and Dense layers. Accepts either: '
                             '- An integer N: Represents a 1:N ratio, meaning one expert layer for every N-1 dense layers '
